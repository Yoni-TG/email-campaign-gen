{
  "id": "holiday-seasonal/gift-guide",
  "name": "Gift Guide",
  "campaignTypes": [
    "holiday_seasonal",
    "collection_spotlight",
    "sale_promo"
  ],
  "tags": [
    "gift-guide",
    "section-labels",
    "warm"
  ],
  "description": "Warm lifestyle hero opens the gift guide, a labelled 2×2 surfaces top picks, and a closing block points to the full guide. Best for Mother's Day, Valentine's, and similar gift-led calendar moments.",
  "requiredAssets": [
    {
      "key": "hero",
      "label": "Hero lifestyle image",
      "required": true
    },
    {
      "key": "closing",
      "label": "Closing image",
      "required": false
    }
  ],
  "blocks": [
    {
      "type": "logo_header",
      "bind": {}
    },
    {
      "type": "announcement_bar",
      "bind": {
        "text": "free_top_text"
      }
    },
    {
      "type": "hero_lifestyle",
      "bind": {
        "imageUrl": "assets.hero",
        "subLabel": "literal:GIFT GUIDE",
        "headline": "body_blocks[0].title",
        "body": "body_blocks[0].description",
        "ctaLabel": "body_blocks[0].cta",
        "ctaHref": "body_blocks[0].cta_href"
      }
    },
    {
      "type": "section_label",
      "bind": {
        "text": "literal:MADE TO TREASURE"
      }
    },
    {
      "type": "product_grid_2x2",
      "bind": {
        "products": "products"
      }
    },
    {
      "type": "closing_block",
      "bind": {
        "imageUrl": "assets.closing",
        "headline": "body_blocks[1].title",
        "body": "body_blocks[1].description",
        "ctaLabel": "body_blocks[1].cta",
        "ctaHref": "body_blocks[1].cta_href"
      }
    },
    {
      "type": "footer",
      "bind": {}
    }
  ]
}
