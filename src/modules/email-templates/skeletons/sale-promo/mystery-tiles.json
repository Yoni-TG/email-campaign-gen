{
  "id": "sale-promo/mystery-tiles",
  "name": "Mystery Tiles",
  "campaignTypes": ["sale_promo"],
  "tags": ["urgent", "graphic-led", "mystery", "today-only"],
  "description": "Three-tile $/?/% graphic hero with urgency banner and short body. Best for time-bound mystery sales and reveal-on-click promos. Hero is graphic — no operator-uploaded image needed.",
  "requiredAssets": [
    { "key": "closing", "label": "Closing image", "required": false }
  ],
  "blocks": [
    { "type": "logo_header", "bind": {} },
    { "type": "announcement_bar", "bind": { "text": "free_top_text" } },
    {
      "type": "hero_tile_graphic",
      "bind": {
        "subLabel": "literal:YOUR MOMENT TO SHINE",
        "headline": "body_blocks[0].title",
        "tiles": [{ "label": "$" }, { "label": "?" }, { "label": "%" }],
        "urgency": "literal:TODAY ONLY",
        "body": "body_blocks[0].description",
        "ctaLabel": "body_blocks[0].cta",
        "ctaHref": "literal:#"
      }
    },
    { "type": "product_grid_2x2", "bind": { "products": "products" } },
    {
      "type": "closing_block",
      "bind": {
        "imageUrl": "assets.closing",
        "headline": "body_blocks[1].title",
        "body": "body_blocks[1].description",
        "ctaLabel": "body_blocks[1].cta",
        "ctaHref": "literal:#"
      }
    },
    { "type": "footer", "bind": {} }
  ]
}
