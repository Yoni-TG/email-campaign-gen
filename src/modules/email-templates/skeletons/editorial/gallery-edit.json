{
  "id": "editorial/gallery-edit",
  "name": "Gallery Edit",
  "campaignTypes": [
    "editorial",
    "collection_spotlight",
    "product_launch"
  ],
  "tags": [
    "gallery",
    "wide-grid",
    "typography-led"
  ],
  "description": "Typography-led headline opens the edit, a 3×2 grid shows the full curated set, and an editorial split closes with a styling note. Best when the edit is broad (10+ pieces) and product-imagery does the storytelling.",
  "requiredAssets": [
    {
      "key": "secondary",
      "label": "Editorial split image",
      "required": true
    }
  ],
  "blocks": [
    {
      "type": "logo_header",
      "bind": {}
    },
    {
      "type": "hero_typography",
      "bind": {
        "topline": "literal:THE EDIT",
        "headline": "body_blocks[0].title",
        "subhead": "body_blocks[0].description",
        "background": "literal:white"
      }
    },
    {
      "type": "section_label",
      "bind": {
        "text": "literal:THE PIECES"
      }
    },
    {
      "type": "product_grid_magazine",
      "bind": {
        "products": "products"
      }
    },
    {
      "type": "editorial_split",
      "bind": {
        "imageUrl": "assets.secondary",
        "imageSide": "literal:right",
        "subLabel": "literal:HOW TO WEAR",
        "headline": "body_blocks[1].title",
        "body": "body_blocks[1].description",
        "ctaLabel": "body_blocks[1].cta",
        "ctaHref": "body_blocks[1].cta_href"
      }
    },
    {
      "type": "footer",
      "bind": {}
    }
  ]
}
