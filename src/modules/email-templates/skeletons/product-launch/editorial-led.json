{
  "id": "product-launch/editorial-led",
  "name": "Editorial · Split · Grid",
  "campaignTypes": [
    "product_launch",
    "editorial",
    "collection_spotlight"
  ],
  "tags": [
    "editorial",
    "image-led",
    "story-forward"
  ],
  "description": "Editorial-split body anchors the launch — image-paired body blocks alternate with the product grid for a magazine-feel reveal. Best when the launch has a clear narrative arc.",
  "requiredAssets": [
    {
      "key": "hero",
      "label": "Hero lifestyle image",
      "required": true
    },
    {
      "key": "secondary",
      "label": "Editorial split image",
      "required": true
    }
  ],
  "blocks": [
    {
      "type": "logo_header",
      "bind": {
        "background": "white"
      }
    },
    {
      "type": "hero_lifestyle",
      "bind": {
        "imageUrl": "assets.hero",
        "subLabel": "literal:THE EDIT",
        "headline": "body_blocks[0].title",
        "body": "body_blocks[0].description",
        "ctaLabel": "body_blocks[0].cta",
        "ctaHref": "body_blocks[0].cta_href"
      }
    },
    {
      "type": "editorial_split",
      "bind": {
        "imageUrl": "assets.secondary",
        "imageSide": "literal:right",
        "subLabel": "literal:HOW TO WEAR",
        "headline": "body_blocks[1].title",
        "body": "body_blocks[1].description",
        "ctaLabel": "body_blocks[1].cta",
        "ctaHref": "body_blocks[1].cta_href"
      }
    },
    {
      "type": "product_grid_2x2",
      "bind": {
        "products": "products"
      }
    },
    {
      "type": "footer",
      "bind": {}
    }
  ]
}
