// Dev: SQLite. Swap `provider` to "postgresql" for prod and change
// String JSON columns to Json in a follow-up migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Campaign {
  id                String   @id @default(uuid())
  name              String
  status            String   @default("draft")
  campaignType      String   @map("campaign_type")
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // JSON blobs stored as stringified JSON on SQLite.
  seed              String

  generatedCopy     String?  @map("generated_copy")
  approvedCopy      String?  @map("approved_copy")
  generatedProducts String?  @map("generated_products")
  approvedProducts  String?  @map("approved_products")

  // Legacy hero upload column. Step 4 drops it; new uploads write to
  // assetPaths under the slot key declared by the chosen skeleton.
  heroImagePath     String?  @map("hero_image_path")

  // Replaces figma_result. JSON-encoded FinalRenderResult — produced by
  // the email-templates renderer after asset_upload completes.
  renderResult      String?  @map("render_result")

  // 3 candidate variants from rendering_candidates. JSON-encoded
  // CandidateVariant[].
  candidateVariants String?  @map("candidate_variants")

  // Skeleton id the operator picked at variant_selection.
  chosenSkeletonId  String?  @map("chosen_skeleton_id")

  // Operator-uploaded asset URLs keyed by AssetSlot.key.
  // JSON-encoded Record<string, string>.
  assetPaths        String?  @map("asset_paths")

  // Per-block prop overrides applied at render time on top of the
  // bind-resolved values. Keyed by block index in the manifest.
  // JSON-encoded Record<string, Partial<BlockProps>>. Used today for
  // background colour fine-tuning; may grow over time.
  blockOverrides    String?  @map("block_overrides")

  error             String?

  // Soft-archive timestamp. Null = active (shown in the default list);
  // non-null = archived (hidden until the operator switches to the
  // archived view). Archive is a UI affordance — the row remains
  // editable / openable / re-renderable; it just gets out of the way.
  archivedAt        DateTime? @map("archived_at")

  @@map("campaigns")
}

// Aggregated Klaviyo analytics, refreshed by the nightly sync (Phase C
// Task 3). One row per (scope, window_start). Scope encodes the
// dimension being measured:
//   - "product:<sku>"            → ProductMetric (rates over the window)
//   - "subject:<campaign_type>"  → SubjectMetric[] (top historical
//                                  subjects for that campaign type)
// `metrics` is a stringified JSON blob on SQLite; flips to Json on the
// Postgres migration.
model KlaviyoMetric {
  id          String   @id @default(uuid())
  scope       String
  windowStart DateTime @map("window_start")
  windowEnd   DateTime @map("window_end")
  metrics     String
  fetchedAt   DateTime @default(now()) @map("fetched_at")

  @@unique([scope, windowStart], map: "klaviyo_metrics_scope_window_uq")
  @@index([scope])
  @@map("klaviyo_metrics")
}
