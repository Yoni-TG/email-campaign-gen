# Database (SQLite for dev; swap to postgresql://... later)
DATABASE_URL="file:./dev.db"

# Anthropic
ANTHROPIC_API_KEY=

# Product feed — custom email-marketing.json served over public CDN
PRODUCT_FEED_URL=https://static.myka.com/us-east-1/imported-feeds/51/email-marketing.json

# Product feed source (optional)
# - Unset: infer (remote when PRODUCT_FEED_URL is set, else local)
# - "remote": always fetch PRODUCT_FEED_URL
# - "local":  always read PRODUCT_FEED_LOCAL_PATH (see data/README.md)
PRODUCT_FEED_SOURCE=
PRODUCT_FEED_LOCAL_PATH=data/product-feed.fixture.json

# Claude model (claude-sonnet-4-6 or claude-opus-4-7)
CLAUDE_MODEL=claude-sonnet-4-6

# Klaviyo (Phase C — historical performance feedback into prompts).
# Private API key, format `pk_...`. Read scopes needed:
# campaigns:read, metrics:read, events:read.
KLAVIYO_API_KEY=

# Klaviyo API revision pin. Bump when we explicitly opt into a newer
# response shape; otherwise leave alone. Format: YYYY-MM-DD.
KLAVIYO_API_REVISION=2026-04-15

# Shared secret guarding POST /api/cron/sync-klaviyo. The lazy
# refresh inside `loadWinningSubjects` keeps `winning-subjects.json`
# fresh on its own (regenerates when the file is > 30 days old).
# This route exists as an optional external trigger / manual override.
# Anything that POSTs here must send
# `Authorization: Bearer <KLAVIYO_SYNC_SECRET>`.
KLAVIYO_SYNC_SECRET=

# Optional. Override the path the winners file is read from / written
# to. Defaults to src/content/winning-subjects.json. Useful in prod
# where src/content/ is part of a read-only image — point this at a
# writable mounted volume.
WINNERS_PATH=

# Base URL for static email assets (images, icons) bundled with the project.
# In dev this is typically empty (assets served from /public).
# In prod point this at the deployment URL or a CDN prefix.
NEXT_PUBLIC_EMAIL_ASSETS_BASE_URL=
